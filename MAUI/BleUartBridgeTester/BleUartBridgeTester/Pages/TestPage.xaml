<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:BleUartBridgeTester.ViewModels"
             xmlns:models="clr-namespace:BleUartBridgeTester.Models"
             x:Class="BleUartBridgeTester.Pages.TestPage"
             Title="Stress Test"
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertBool" />
        <toolkit:BoolToObjectConverter x:Key="BoolToConnectedColor"
            TrueObject="{StaticResource ConnectedColor}"
            FalseObject="{StaticResource DisconnectedColor}" />
        <toolkit:BoolToObjectConverter x:Key="BoolToRunningColor"
            TrueObject="{StaticResource Secondary}"
            FalseObject="{StaticResource TextSecondary}" />
        <toolkit:BoolToObjectConverter x:Key="BoolToConnectedText"
            TrueObject="Connected"
            FalseObject="Not connected" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Top bar -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                             BackgroundColor="{Binding IsConnected,
                                 Converter={StaticResource BoolToConnectedColor}}"
                             VerticalOptions="Center" />
                    <Label Text="{Binding IsConnected,
                               Converter={StaticResource BoolToConnectedText}}"
                           TextColor="{Binding IsConnected,
                               Converter={StaticResource BoolToConnectedColor}}"
                           VerticalOptions="Center" FontAttributes="Bold" />
                </HorizontalStackLayout>
                <Label Grid.Column="1" Text="Stop on error:"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextSecondary}" />
                <Switch Grid.Column="2" IsToggled="{Binding StopOnError}"
                        VerticalOptions="Center" />
                <Button Grid.Column="3"
                        Text="Stop All"
                        Command="{Binding StopAllTestsCommand}"
                        Style="{StaticResource DangerButton}"
                        IsEnabled="{Binding IsConnected}" />
            </Grid>

            <!-- Rx delay bars — one per direction -->
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0" Text="COM→BLE Rx delay:"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Primary}" />
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding ComToBleSimDelayEnabled}"
                          VerticalOptions="Center" />
                <Label Grid.Column="2" Text="0"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextSecondary}" />
                <Slider Grid.Column="3"
                        Minimum="0" Maximum="300"
                        Value="{Binding ComToBleSimDelayMaxMs}"
                        IsEnabled="{Binding ComToBleSimDelayEnabled}"
                        VerticalOptions="Center" />
                <Label Grid.Column="4"
                       Text="{Binding ComToBleSimDelayMaxMs, StringFormat='{0:F0} ms'}"
                       VerticalOptions="Center" MinimumWidthRequest="52"
                       TextColor="{Binding ComToBleSimDelayEnabled,
                           Converter={StaticResource BoolToRunningColor}}" />
            </Grid>
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                <Label Grid.Column="0" Text="BLE→COM Rx delay:"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Secondary}" />
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding BleToComSimDelayEnabled}"
                          VerticalOptions="Center" />
                <Label Grid.Column="2" Text="0"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextSecondary}" />
                <Slider Grid.Column="3"
                        Minimum="0" Maximum="300"
                        Value="{Binding BleToComSimDelayMaxMs}"
                        IsEnabled="{Binding BleToComSimDelayEnabled}"
                        VerticalOptions="Center" />
                <Label Grid.Column="4"
                       Text="{Binding BleToComSimDelayMaxMs, StringFormat='{0:F0} ms'}"
                       VerticalOptions="Center" MinimumWidthRequest="52"
                       TextColor="{Binding BleToComSimDelayEnabled,
                           Converter={StaticResource BoolToRunningColor}}" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

            <!-- ── COM → BLE Test ── -->
            <Frame Style="{StaticResource CardFrame}" BorderColor="{StaticResource Primary}">
                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                     BackgroundColor="{Binding IsComTestRunning,
                                         Converter={StaticResource BoolToRunningColor}}"
                                     VerticalOptions="Center" />
                            <Label Text="COM → BLE Stress Test"
                                   Style="{StaticResource SectionHeader}"
                                   TextColor="{StaticResource Primary}"
                                   Margin="0" />
                            <ActivityIndicator IsRunning="{Binding IsComTestRunning}"
                                               IsVisible="{Binding IsComTestRunning}"
                                               Color="{StaticResource Primary}"
                                               VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding ComTestStats.Elapsed}"
                               FontFamily="Courier New"
                               FontSize="14"
                               TextColor="{Binding IsComTestRunning,
                                   Converter={StaticResource BoolToRunningColor}}"
                               VerticalOptions="Center" />
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <Button Text="▶ Start"
                                Command="{Binding StartComTestCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding IsComTestRunning,
                                    Converter={StaticResource InvertBool}}" />
                        <Button Text="■ Stop"
                                Command="{Binding StopComTestCommand}"
                                Style="{StaticResource DangerButton}"
                                IsEnabled="{Binding IsComTestRunning}" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="8" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Sent:"         Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding ComTestStats.PacketsSent}" Style="{StaticResource StatValue}" />
                        <Label Grid.Row="0" Grid.Column="2" Text="Received:"     Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="0" Grid.Column="3" Text="{Binding ComTestStats.PacketsReceived}" Style="{StaticResource StatValue}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Errors:"       Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding ComTestStats.Errors}"
                               Style="{StaticResource StatValue}"
                               TextColor="{StaticResource Danger}" />
                        <Label Grid.Row="1" Grid.Column="2" Text="Speed:"        Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="1" Grid.Column="3"
                               Text="{Binding ComTestStats.BytesPerSec, StringFormat='{0:F0} B/s'}"
                               Style="{StaticResource StatValue}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Lat Avg:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding ComTestStats.LatencyAvgMs, StringFormat='{0:F1} ms'}"
                               Style="{StaticResource StatValue}" />
                        <Label Grid.Row="2" Grid.Column="2" Text="Lat Min:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="2" Grid.Column="3"
                               Text="{Binding ComTestStats.LatencyMinDisplay}"
                               Style="{StaticResource StatValue}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Lat Max:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding ComTestStats.LatencyMaxMs, StringFormat='{0:F1} ms'}"
                               Style="{StaticResource StatValue}" />
                    </Grid>

                    <!-- Error dump -->
                    <Frame IsVisible="{Binding ComTestHasError}"
                           BackgroundColor="#FEF2F2" BorderColor="{StaticResource Danger}"
                           CornerRadius="4" Padding="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ComTestErrorType}"
                                   FontAttributes="Bold" FontSize="11"
                                   TextColor="{StaticResource Danger}" />
                            <Grid ColumnDefinitions="*,1,*" ColumnSpacing="0" HeightRequest="140">
                                <ScrollView Grid.Column="0">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Expected" FontAttributes="Bold" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding ComTestErrorSent}"
                                               Style="{StaticResource HexDump}" />
                                    </VerticalStackLayout>
                                </ScrollView>
                                <BoxView Grid.Column="1" Color="{StaticResource BorderColor}" />
                                <ScrollView Grid.Column="2">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Received" FontAttributes="Bold" FontSize="10"
                                               TextColor="{StaticResource Danger}" />
                                        <Label Text="{Binding ComTestErrorReceived}"
                                               Style="{StaticResource HexDump}" />
                                    </VerticalStackLayout>
                                </ScrollView>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- ── BLE → COM Test ── -->
            <Frame Style="{StaticResource CardFrame}" BorderColor="{StaticResource Secondary}">
                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                     BackgroundColor="{Binding IsBleTestRunning,
                                         Converter={StaticResource BoolToRunningColor}}"
                                     VerticalOptions="Center" />
                            <Label Text="BLE → COM Stress Test"
                                   Style="{StaticResource SectionHeader}"
                                   TextColor="{StaticResource Secondary}"
                                   Margin="0" />
                            <ActivityIndicator IsRunning="{Binding IsBleTestRunning}"
                                               IsVisible="{Binding IsBleTestRunning}"
                                               Color="{StaticResource Secondary}"
                                               VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding BleTestStats.Elapsed}"
                               FontFamily="Courier New"
                               FontSize="14"
                               TextColor="{Binding IsBleTestRunning,
                                   Converter={StaticResource BoolToRunningColor}}"
                               VerticalOptions="Center" />
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <Button Text="▶ Start"
                                Command="{Binding StartBleTestCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding IsBleTestRunning,
                                    Converter={StaticResource InvertBool}}" />
                        <Button Text="■ Stop"
                                Command="{Binding StopBleTestCommand}"
                                Style="{StaticResource DangerButton}"
                                IsEnabled="{Binding IsBleTestRunning}" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="8" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Sent:"         Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding BleTestStats.PacketsSent}" Style="{StaticResource StatValue}" />
                        <Label Grid.Row="0" Grid.Column="2" Text="Received:"     Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="0" Grid.Column="3" Text="{Binding BleTestStats.PacketsReceived}" Style="{StaticResource StatValue}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Errors:"       Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding BleTestStats.Errors}"
                               Style="{StaticResource StatValue}"
                               TextColor="{StaticResource Danger}" />
                        <Label Grid.Row="1" Grid.Column="2" Text="Speed:"        Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="1" Grid.Column="3"
                               Text="{Binding BleTestStats.BytesPerSec, StringFormat='{0:F0} B/s'}"
                               Style="{StaticResource StatValue}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Lat Avg:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding BleTestStats.LatencyAvgMs, StringFormat='{0:F1} ms'}"
                               Style="{StaticResource StatValue}" />
                        <Label Grid.Row="2" Grid.Column="2" Text="Lat Min:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="2" Grid.Column="3"
                               Text="{Binding BleTestStats.LatencyMinDisplay}"
                               Style="{StaticResource StatValue}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Lat Max:"      Style="{StaticResource StatLabel}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding BleTestStats.LatencyMaxMs, StringFormat='{0:F1} ms'}"
                               Style="{StaticResource StatValue}" />
                    </Grid>

                    <!-- Error dump -->
                    <Frame IsVisible="{Binding BleTestHasError}"
                           BackgroundColor="#FEF2F2" BorderColor="{StaticResource Danger}"
                           CornerRadius="4" Padding="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding BleTestErrorType}"
                                   FontAttributes="Bold" FontSize="11"
                                   TextColor="{StaticResource Danger}" />
                            <Grid ColumnDefinitions="*,1,*" ColumnSpacing="0" HeightRequest="120">
                                <ScrollView Grid.Column="0">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Expected" FontAttributes="Bold" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding BleTestErrorSent}"
                                               Style="{StaticResource HexDump}" />
                                    </VerticalStackLayout>
                                </ScrollView>
                                <BoxView Grid.Column="1" Color="{StaticResource BorderColor}" />
                                <ScrollView Grid.Column="2">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Received" FontAttributes="Bold" FontSize="10"
                                               TextColor="{StaticResource Danger}" />
                                        <Label Text="{Binding BleTestErrorReceived}"
                                               Style="{StaticResource HexDump}" />
                                    </VerticalStackLayout>
                                </ScrollView>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- Packet format info -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Packet format: [seq:4][len:2][payload:8-107][crc8:2]"
                           FontFamily="Courier New" FontSize="11"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Text="Payload: variable (seq%100+8 bytes), content = (seq+i) &amp; 0xFF"
                           FontFamily="Courier New" FontSize="11"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Text="CRC: CRC-8/SMBUS over seq+len+payload"
                           FontFamily="Courier New" FontSize="11"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
